# Magnific API Client - Environment Variables
# Copy this file to .env and fill in the values

# Path to cookies file (Netscape format or JSON)
COOKIES_FILE=cookies.txt

# API Server Configuration
API_HOST=0.0.0.0
API_PORT=8080

# Base URL
BASE_URL=https://www.freepik.com

# Polling
POLL_INTERVAL=5
POLL_TIMEOUT=180

# Download
DOWNLOAD_DIR=./downloads
